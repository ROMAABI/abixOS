# AbixOS Dotfiles - .gitignore

# ============================================
# Cache & Temporary Files
# ============================================
.cache/
*.cache
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# ============================================
# Local State & Runtime Data
# ============================================
.local/state/
.local/share/applications/
.local/share/icons/
.local/share/kio/
.state/

# ============================================
# Build & Dependencies
# ============================================
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
venv/
env/

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# Backup Files
# ============================================
*.bak
*.backup
*~
*.orig

# ============================================
# IDE & Editor
# ============================================
.idea/
.vscode/
*.code-workspace
*.sublime-*

# ============================================
# Hyprland Runtime
# ============================================
hypr/**/*.log
waybar/**/*.log
rofi/**/*.log

# ============================================
# Exclude specific sensitive dirs
# ============================================
.ssh/
.gpg/
# ============================================
# Wallpapers - Excluded (too large for Git)
# ============================================
abix*/**/wallpapers/
wallpapers/


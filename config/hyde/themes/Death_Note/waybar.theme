$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(251, 191, 36, 0.1);
@define-color main-bg rgba(251, 191, 36, 0.85);
@define-color main-fg #fef3c7;
@define-color wb-act-bg rgba(251, 191, 36, 0.5);
@define-color wb-act-fg #fef3c7;
@define-color wb-hvr-bg rgba(251, 191, 36, 0.7);
@define-color wb-hvr-fg #ffffff;

$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
/* Spiderman - Red + Black aesthetic */
@define-color bar-bg rgba(2, 6, 23, 0.1);

@define-color main-bg rgba(2, 6, 23, 0.85);
@define-color main-fg #f1f5f9;

@define-color wb-act-bg rgba(225, 29, 72, 0.5);
@define-color wb-act-fg #fecdd3;

@define-color wb-hvr-bg rgba(225, 29, 72, 0.8);
@define-color wb-hvr-fg #fff1f2;

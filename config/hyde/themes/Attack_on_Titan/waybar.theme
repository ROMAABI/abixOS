$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(153, 27, 27, 0.1);
@define-color main-bg rgba(153, 27, 27, 0.85);
@define-color main-fg #fecaca;
@define-color wb-act-bg rgba(153, 27, 27, 0.5);
@define-color wb-act-fg #fecaca;
@define-color wb-hvr-bg rgba(153, 27, 27, 0.7);
@define-color wb-hvr-fg #ffffff;

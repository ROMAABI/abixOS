$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(124, 58, 237, 0.1);
@define-color main-bg rgba(124, 58, 237, 0.85);
@define-color main-fg #e9d5ff;
@define-color wb-act-bg rgba(124, 58, 237, 0.5);
@define-color wb-act-fg #e9d5ff;
@define-color wb-hvr-bg rgba(124, 58, 237, 0.7);
@define-color wb-hvr-fg #ffffff;

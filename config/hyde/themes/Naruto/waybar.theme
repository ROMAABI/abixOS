$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(234, 88, 12, 0.1);
@define-color main-bg rgba(234, 88, 12, 0.85);
@define-color main-fg #ffedd5;
@define-color wb-act-bg rgba(234, 88, 12, 0.5);
@define-color wb-act-fg #ffedd5;
@define-color wb-hvr-bg rgba(234, 88, 12, 0.7);
@define-color wb-hvr-fg #ffffff;

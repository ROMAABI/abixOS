$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(120, 53, 15, 0.1);
@define-color main-bg rgba(120, 53, 15, 0.85);
@define-color main-fg #fef3c7;
@define-color wb-act-bg rgba(120, 53, 15, 0.5);
@define-color wb-act-fg #fef3c7;
@define-color wb-hvr-bg rgba(120, 53, 15, 0.7);
@define-color wb-hvr-fg #ffffff;

$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(220, 38, 38, 0.1);
@define-color main-bg rgba(220, 38, 38, 0.85);
@define-color main-fg #fee2e2;
@define-color wb-act-bg rgba(220, 38, 38, 0.5);
@define-color wb-act-fg #fee2e2;
@define-color wb-hvr-bg rgba(220, 38, 38, 0.7);
@define-color wb-hvr-fg #ffffff;

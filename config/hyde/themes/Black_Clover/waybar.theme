$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(34, 197, 94, 0.1);
@define-color main-bg rgba(34, 197, 94, 0.85);
@define-color main-fg #bbf7d0;
@define-color wb-act-bg rgba(34, 197, 94, 0.5);
@define-color wb-act-fg #bbf7d0;
@define-color wb-hvr-bg rgba(34, 197, 94, 0.7);
@define-color wb-hvr-fg #ffffff;

$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(101, 163, 13, 0.1);
@define-color main-bg rgba(101, 163, 13, 0.85);
@define-color main-fg #d9f99d;
@define-color wb-act-bg rgba(101, 163, 13, 0.5);
@define-color wb-act-fg #d9f99d;
@define-color wb-hvr-bg rgba(101, 163, 13, 0.7);
@define-color wb-hvr-fg #ffffff;

$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(219, 39, 119, 0.1);
@define-color main-bg rgba(219, 39, 119, 0.85);
@define-color main-fg #fce7f3;
@define-color wb-act-bg rgba(219, 39, 119, 0.5);
@define-color wb-act-fg #fce7f3;
@define-color wb-hvr-bg rgba(219, 39, 119, 0.7);
@define-color wb-hvr-fg #ffffff;

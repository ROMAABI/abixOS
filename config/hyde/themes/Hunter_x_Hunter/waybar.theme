$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh
@define-color bar-bg rgba(5, 150, 105, 0.1);
@define-color main-bg rgba(5, 150, 105, 0.85);
@define-color main-fg #d1fae5;
@define-color wb-act-bg rgba(5, 150, 105, 0.5);
@define-color wb-act-fg #d1fae5;
@define-color wb-hvr-bg rgba(5, 150, 105, 0.7);
@define-color wb-hvr-fg #ffffff;
